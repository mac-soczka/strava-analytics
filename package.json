{
  "name": "strava-heatmap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    
    "dev:full": "npm run supabase:local:start && npm run dev",
    
    "supabase:local:start": "npx supabase start",
    "supabase:local:stop": "npx supabase stop",
    "supabase:local:status": "npx supabase status",
    "supabase:local:studio": "npx supabase studio",
    "supabase:local:reset": "npx supabase db reset",
    "supabase:local:pull": "npx supabase db pull",
    "supabase:local:diff": "npx supabase db diff",
    
    "supabase:migration:new": "npx supabase migration new",
    "supabase:migration:list": "npx supabase migration list",
    "supabase:migration:list:local": "npx supabase migration list --local",
    "supabase:migration:list:prod": "npx supabase migration list",
    
    "supabase:prod:push": "npx supabase db push",
    "supabase:prod:push:all": "npx supabase db push --include-all",
    "supabase:prod:pull": "npx supabase db pull",
    "supabase:prod:diff": "npx supabase db diff",
    
    "db:local:setup": "npm run supabase:local:start && npm run supabase:local:reset && npm run supabase:local:studio",
    "db:local:studio": "npm run supabase:local:start && npm run supabase:local:studio",
    "db:prod:apply": "npm run supabase:prod:push:all",
    "db:prod:sync": "npm run supabase:prod:pull && npm run supabase:prod:push:all"
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.52.0",
    "axios": "^1.10.0",
    "dotenv": "^17.2.0",
    "leaflet": "^1.9.4",
    "next": "^15.4.2",
    "open": "^10.2.0",
    "react": "^19.0.0",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
