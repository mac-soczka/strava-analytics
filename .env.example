# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Strava
STRAVA_CLIENT_ID=your-client-id-here
STRAVA_CLIENT_SECRET=your-client-secret-here

# Optional: override OAuth callback URL
# If omitted, the app uses NEXT_PUBLIC_APP_URL, then VERCEL_URL, then localhost.
# STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Optional: app base URL (used to derive redirect URI)
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional: bypass internal request pacing (development/testing)
# STRAVA_NO_LIMITS=true
